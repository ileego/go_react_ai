# 默认所有文本文件使用 LF
* text=auto eol=lf

# 显式标记为文本的文件类型
*.go text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.mod text eol=lf
*.sum text eol=lf
Makefile text eol=lf

# 二进制文件不转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
