# 复制为 .env 后填入真实值

# 服务
SERVER_PORT=8080
SERVER_MODE=debug
ALLOW_ORIGINS=*
LOG_LEVEL=info
LOG_FORMAT=json

# 数据库
DB_HOST=localhost
DB_PORT=5432
DB_USER=goai
DB_PASSWORD=goai_dev
DB_NAME=goai
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME_MINUTES=30
DB_CONN_MAX_IDLE_TIME_MINUTES=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=goai-files

# AI API Keys
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_BASE_URL=https://api.anthropic.com

DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com

KIMI_API_KEY=sk-xxx
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Worker Pool 与 AI 调用配置
WORKER_POOL_WORKERS=4
WORKER_POOL_QUEUE_SIZE=8
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=3

# 认证与 JWT（生产环境必须替换 JWT_SECRET）
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7

# GitHub OAuth2（可选，不配置则关闭第三方登录）
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URL=http://localhost:8080/api/auth/github/callback
