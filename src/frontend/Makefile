.PHONY: help install dev build lint test preview

# 默认显示帮助
help:
	@echo "前端可用命令:"
	@echo "  make install   - 安装依赖 (pnpm install)"
	@echo "  make dev       - 启动开发服务器"
	@echo "  make build     - 生产构建"
	@echo "  make lint      - 运行 ESLint 检查"
	@echo "  make test      - 运行测试"
	@echo "  make preview   - 预览生产构建"

# 安装依赖
install:
	pnpm install

# 启动开发服务器
dev:
	pnpm dev

# 生产构建
build:
	pnpm build

# 代码检查
lint:
	pnpm lint

# 运行测试
test:
	pnpm test

# 预览生产构建
preview:
	pnpm preview
